{
  // AINumbers MCP Apps — Cloudflare Workers config.
  // First deploy: `npx wrangler deploy` → test at the printed workers.dev URL.
  // Cutover: uncomment "routes" below, delete the existing mcp CNAME → Render in the
  // Cloudflare DNS dashboard, then `npx wrangler deploy` again (creates the custom-domain record).
  "name": "ainumbers-mcp",
  "main": "worker.mjs",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "assets": {
    "directory": "./data",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [{ "pattern": "mcp.ainumbers.co", "custom_domain": true }],
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "mcp_tool_calls" }
  ],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  // GAP-d event substrate (2026-07-10): weekly cron feeds GAP-a/EXPORT-1/suggestion-digest.
  // Queue is producer+consumer on THIS worker, Free-plan sizing (10k ops/day cap; design
  // target <100/day — three orders of magnitude under cap, see worker.mjs scheduled()).
  "triggers": {
    "crons": ["0 6 * * 1"]
  },
  "queues": {
    "producers": [
      { "queue": "ainumbers-events", "binding": "EVENTS_QUEUE" }
    ],
    "consumers": [
      { "queue": "ainumbers-events" }
    ]
  },
  // GAP-a (2026-07-10): CF Workflows durable orchestration. 1 step.do = 1 receipted kernel/check
  // run (see workflows/renewal-watch-workflow.mjs); durability sits UNDER the receipt layer, never
  // becomes the source of truth. Free-plan Workflows (GA, no paid-plan requirement): 3-day state
  // retention / 30s CPU per step — design checkpoints any >3-day wait to a signed artifact rather
  // than relying on Workflows-internal state (see GAP-A-DESIGN-DOC.md §A.3). Rides the live GAP-d
  // envelope (worker.mjs queue()); no new MCP tool, no /mcp behavior change.
  "workflows": [
    {
      "name": "renewal-watch",
      "binding": "RENEWAL_WATCH_WORKFLOW",
      "class_name": "RenewalWatchWorkflow"
    }
  ]
}
