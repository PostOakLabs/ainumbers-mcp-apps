#!/usr/bin/env sh
# pre-push — LOCAL PREFLIGHT GATE.
#
# Runs scripts/preflight.mjs, which mirrors the "Validate MCP server" CI job (tool-name collisions,
# surface-parity/counts, worker hot-path invariants, build-parity + pre-deploy count guard, kernel
# coverage, validate-chains, vendor-freshness, schema-validate) — so a red push never leaves the
# machine. Replaces the old vendor-freshness-ONLY hook, which let count-drift + surface-parity
# failures sail through to CI (run_chain's two red master deploys, 2026-06-29).
#
# Travels with the repo: installed via the package.json "prepare" script (core.hooksPath=.githooks).
# Vendor-freshness inside preflight compares against the site COMMITTED HEAD, so a concurrent session's
# uncommitted WIP in ../repo no longer false-blocks the push.
#
# Gates EVERY push, not just master. A feature-branch push opens/updates a PR that runs the SAME
# gate suite in CI, so gating only master let feature pushes surface failures at CI instead of here —
# wasting a push -> CI-red -> fix -> re-push cycle (e.g. the AUD-C2 export-format false-positive on
# art-251, 2026-07-09, which this local suite catches before the push). Matches the site hook, which
# already gates all pushes. Override a known-red WIP push with:  git push --no-verify
[ -f scripts/preflight.mjs ] || exit 0

node scripts/preflight.mjs
rc=$?
if [ "$rc" != 0 ]; then
  echo "" >&2
  echo "⛔ pre-push BLOCKED: worker preflight failed — this is what CI would reject." >&2
  echo "   Fix the gate(s) listed above, then push again." >&2
  echo "   (override for an unrelated push: git push --no-verify)" >&2
  exit 1
fi
exit 0
