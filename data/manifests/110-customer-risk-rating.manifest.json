{
  "tool_id": "110-customer-risk-rating",
  "version": "1.1.0",
  "title": "Customer Risk Rating Engine",
  "description": "Score individual and entity KYC risk across six FATF dimensions: customer type, product/service type, delivery channel, geographic risk, transaction behaviour,",
  "category": "aml-kyc",
  "tags": [],
  "audience": [
    "payments",
    "compliance",
    "finance",
    "engineer"
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "customerType": {
        "type": "string",
        "description": "Customer category (retail/corporate/pep/correspondent)"
      },
      "productType": {
        "type": "string",
        "description": "Product type (payments/lending/custody/fx)"
      },
      "geoRisk": {
        "type": "string",
        "description": "Geography risk level (low/medium/high/sanctioned)"
      },
      "channel": {
        "type": "string",
        "description": "Onboarding channel (branch/digital/introducer/correspondent)"
      },
      "txnBehaviour": {
        "type": "string",
        "description": "Transaction behaviour risk (low/medium/high)"
      },
      "adverseMedia": {
        "type": "string",
        "description": "Adverse media findings (none/minor/material/severe)"
      },
      "w1": {
        "type": "string",
        "description": "Weight for customer type (0–100)"
      },
      "w2": {
        "type": "string",
        "description": "Weight for product (0–100)"
      },
      "w3": {
        "type": "string",
        "description": "Weight for geography (0–100)"
      },
      "w4": {
        "type": "string",
        "description": "Weight for channel (0–100)"
      },
      "w5": {
        "type": "string",
        "description": "Weight for transaction behaviour (0–100)"
      },
      "w6": {
        "type": "string",
        "description": "Weight for adverse media (0–100)"
      }
    },
    "required": [
      "customerType",
      "productType",
      "geoRisk",
      "channel"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "compositeScore": {
        "type": "number"
      },
      "riskTier": {
        "type": "string"
      },
      "breakdown": {
        "type": "array"
      },
      "mandateJson": {
        "type": "object"
      }
    }
  },
  "mcp_tool_definition": {
    "name": "customer_risk_rating",
    "description": "Score individual and entity KYC risk across six FATF dimensions: customer type, product/service type, delivery channel, geographic risk, transaction behaviour, Browser-based, client-side only. Zero PII. Link users to https://ainumbers.co/tools/110-customer-risk-rating.html for interactive use.",
    "inputSchema": {
      "type": "object",
      "properties": {}
    }
  },
  "execution": {
    "type": "browser-reference",
    "entry": "tools/110-customer-risk-rating.html",
    "function_name": "calcRisk"
  },
  "ap2_export": true,
  "pii_transmitted": false,
  "execution_context": "client_side_browser",
  "prefill": true,
  "bridge_version": "1.0"
}
